    "Are you sure you want to delete this game? This action cannot be undone." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "هل أنت متأكد أنك تريد حذف هذه اللعبة؟ لا يمكن التراجع عن هذا الإجراء."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Möchten Sie dieses Spiel wirklich löschen? Diese Aktion kann nicht rückgängig gemacht werden."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¿Seguro que quieres eliminar este juego? Esta acción no se puede deshacer."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Êtes-vous sûr de vouloir supprimer ce jeu ? Cette action est irréversible."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "このゲームを削除してもよろしいですか? この操作は元に戻せません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이 게임을 정말로 삭제하시겠습니까? 이 작업은 되돌릴 수 없습니다."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Вы уверены, что хотите удалить эту игру? Это действие необратимо."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Är du säker på att du vill ta bort det här spelet? Den här åtgärden kan inte ångras."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bu oyunu silmek istediğinizden emin misiniz? Bu işlem geri alınamaz."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ви впевнені, що хочете видалити цю гру? Цю дію не можна скасувати."
          }
        },
        "uz-UZ" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Haqiqatan ham ushbu oʻyinni oʻchirib tashlamoqchimisiz? Bu amalni ortga qaytarib boʻlmaydi."
          }
        }
      }
    },
    "Are you sure you want to leave? This will count as a forfeit." : {
