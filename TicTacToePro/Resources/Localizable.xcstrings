    "This will reset all settings to their default values. This action cannot be undone." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "سيؤدي ذلك إلى إعادة جميع الإعدادات إلى القيم الافتراضية. لا يمكن التراجع عن هذا الإجراء."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dadurch werden alle Einstellungen auf ihre Standardwerte zurückgesetzt. Diese Aktion kann nicht rückgängig gemacht werden."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esto restablecerá todos los ajustes a sus valores predeterminados. Esta acción no se puede deshacer."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cela réinitialisera tous les paramètres. Cette action est irréversible."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "すべての設定がデフォルト値にリセットされます。この操作は元に戻せません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이렇게 하면 모든 설정이 기본값으로 초기화됩니다. 이 작업은 되돌릴 수 없습니다."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Все настройки будут сброшены. Это действие нельзя отменить."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Detta återställer alla inställningar till standardvärdena. Åtgärden kan inte ångras."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bu işlem tüm ayarları varsayılan değerlerine sıfırlayacaktır. Bu işlem geri alınamaz."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Це скине всі налаштування до значень за замовчуванням. Цю дію не можна скасувати."
          }
        },
        "uz-UZ" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bu barcha sozlamalarni standart qiymatlariga qaytaradi. Bu amalni bekor qilib bo'lmaydi."
