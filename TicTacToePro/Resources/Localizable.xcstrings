    "A modern take on the classic game with stunning visuals, multiplayer support, and AI opponents." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "نسخة عصرية من اللعبة الكلاسيكية برسومات مذهلة، ودعم للعب الجماعي، وخصوم يتحكم بهم الذكاء الاصطناعي."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Eine moderne Interpretation des Klassikers mit atemberaubender Grafik, Mehrspielerunterstützung und KI-Gegnern."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Una versión moderna del juego clásico con gráficos impresionantes, soporte multijugador y oponentes controlados por IA."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Une version moderne du jeu classique avec des graphismes époustouflants, un mode multijoueur et des adversaires IA."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "素晴らしいビジュアル、マルチプレイヤー サポート、AI 対戦相手を備えた、クラシック ゲームを現代風にアレンジした作品です。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "놀라운 그래픽, 멀티플레이어 지원, 그리고 AI 상대까지 갖춘 현대적으로 재해석된 고전 게임입니다."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Современная интерпретация классической игры с потрясающей графикой, поддержкой многопользовательского режима и противниками, управляемыми искусственным интеллектом."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En modern version av det klassiska spelet med fantastisk grafik, stöd för flera spelare och AI-motståndare."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Çarpıcı görselleri, çok oyunculu desteği ve yapay zekâ rakipleriyle klasik oyunun modern bir yorumu."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Сучасна інтерпретація класичної гри з приголомшливою графікою, підтримкою багатокористувацького режиму та суперниками зі штучним інтелектом."
          }
        },
        "uz-UZ" : {
          "stringUnit" : {
            "state" : "translated",
